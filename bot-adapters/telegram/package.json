  },
  "dependencies": {
    "@support-agent-asp/agent-core": "*",
    "telegraf": "^4.16.3",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
