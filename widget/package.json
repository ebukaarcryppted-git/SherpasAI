{
  "name": "@support-agent-asp/widget",
  "version": "0.2.0",
  "description": "Embeddable support widget — diagnoses a failed onchain transaction and offers a one-click wallet fix where the failure mode allows it. React component (npm) or a script-tag embed for non-React sites.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "wagmi": "^2.12.0",
    "viem": "^2.21.0",
    "@tanstack/react-query": "^5.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "build:embed": "node esbuild.embed.mjs",
    "build:all": "npm run build && npm run build:embed",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@tanstack/react-query": "^5.59.0",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "esbuild": "^0.24.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "typescript": "^5.6.0",
    "viem": "^2.21.0",
    "vitest": "^2.1.0",
    "wagmi": "^2.12.0"
  }
}
