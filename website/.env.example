# Widget-backend proxy for pay-as-you-go diagnose_transaction calls
# (app/api/diagnose-proxy/route.ts). This is the "protocol's own backend" from
# the Payment Phase spec — it holds the funded wallet key server-side so the
# end user's browser never touches payment. Point a deployed widget's
# `mcpEndpoint` prop at /api/diagnose-proxy instead of directly at the MCP
# server once these are set.

# URL of the (payment-gated) sherpas-support-mcp-server HTTP transport.
MCP_SERVER_URL=

# The embedding protocol's own funded wallet — pays for every diagnosis on
# the end user's behalf. Never exposed to the browser; never commit a real key.
DIAGNOSIS_PAYER_PRIVATE_KEY=

# Must match the gated server's own MPP_CURRENCY / MPP_RECIPIENT exactly.
MPP_CURRENCY=
MPP_RECIPIENT=

# Optional: override OKX's shared MPP escrow contract on X Layer.
MPP_ESCROW=

# EIP-3009 domain of the MPP_CURRENCY token contract — needed only for the
# one-time channel `open` (and occasional `topUp`), not for the recurring
# per-call voucher signing. Must match the real deployed token's own
# EIP-712 domain (name/version) or `open` will fail signature verification.
MPP_TOKEN_NAME=
MPP_TOKEN_VERSION=

# Optional: where the channel state (channelId, cumulative spend) persists
# across restarts.
MPP_CHANNEL_STORE_PATH=
