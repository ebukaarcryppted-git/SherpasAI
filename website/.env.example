# Widget-backend proxy for pay-as-you-go diagnose_transaction calls
# (app/api/diagnose-proxy/route.ts). Holds the funded wallet key server-side
# so the end user's browser never touches payment. Point a deployed widget's
# `mcpEndpoint` prop at /api/diagnose-proxy instead of directly at the MCP
# server once these are set.
#
# Uses the x402 protocol — no token/recipient/domain config needed here,
# the gated server's own 402 response declares all of that dynamically.

# URL of the (payment-gated) sherpas-support-mcp-server HTTP transport.
MCP_SERVER_URL=

# The embedding protocol's own funded wallet — pays for every diagnosis on
# the end user's behalf. Never exposed to the browser; never commit a real key.
DIAGNOSIS_PAYER_PRIVATE_KEY=
