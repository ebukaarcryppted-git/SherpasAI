{
  "name": "sherpas-support-mcp-server",
  "version": "0.1.0",
  "description": "MCP server exposing Sherpas Agent's onchain transaction diagnosis as a callable tool (diagnose_transaction) — reads live X Layer / Ethereum chain state and classifies failures via a rule-based engine.",
  "type": "module",
  "bin": {
    "sherpas-support-mcp-server": "dist/index.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:http": "MCP_TRANSPORT=http tsx src/index.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "@okxweb3/mpp": "^0.1.0",
    "@support-agent-asp/agent-core": "*",
    "@support-agent-asp/onchain-reader": "*",
    "viem": "^2.21.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
