# Pay-as-you-go gating for diagnose_transaction (x402 "exact" scheme —
# required for OKX.AI A2MCP compliance; see docs/asp-registration.md).
# All four must be set for the tool to be payment-gated; if any is missing,
# the server logs "running ungated" and serves diagnose_transaction for free
# (useful for local dev, never for a real deployment).

# OKX API credentials (Settlement Agent / SA API) — used to authenticate
# with OKX's x402 facilitator, which verifies and settles payments on-chain
# on your behalf. https://web3.okx.com/onchainos/dev-docs/home/developer-portal
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# The address that receives payment for each diagnosis. No private key or
# gas-funded wallet needed here — the facilitator submits settlement
# transactions itself, this is just a receiving address.
X402_PAY_TO=

# Optional: where the accounting ledger (payment-receipts.jsonl) is written.
RECEIPT_LOG_PATH=
