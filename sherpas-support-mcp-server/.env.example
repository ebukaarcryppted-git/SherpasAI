# Pay-as-you-go gating for diagnose_transaction (OKX onchainOS MPP session).
# All five must be set for the tool to be payment-gated; if any is missing,
# the server logs "running ungated" and serves diagnose_transaction for free
# (useful for local dev, never for a real deployment).

# OKX API credentials (Settlement Agent / SA API) — https://web3.okx.com
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Seller's own key for signing Challenges (HMAC) — generate with:
#   openssl rand -base64 32
MPP_SECRET_KEY=

# The revenue wallet's private key — signs SettleAuthorization/CloseAuthorization
# when settling a channel. Never commit a real key.
MPP_MERCHANT_PRIVATE_KEY=

# The token being charged (must be an EIP-3009-compatible stablecoin —
# USD₮0/USDG on X Layer) and the payee address that receives it.
MPP_CURRENCY=
MPP_RECIPIENT=

# Optional: override OKX's shared MPP escrow contract on X Layer.
# Defaults to 0x5E550002e64FaF79B41D89fE8439eEb1be66CE3b if unset.
MPP_ESCROW=

# Optional: where the accounting ledger (payment-receipts.jsonl) is written.
RECEIPT_LOG_PATH=
